#!/usr/bin/env sh
# Global gitleaks pre-commit hook (personal machine protection).
# Runs in every repo that does not override core.hooksPath locally (e.g. no Husky).
if command -v gitleaks >/dev/null 2>&1; then
if ! gitleaks protect --staged --no-banner --verbose --redact; then
    echo ""
    echo "----------------------------------------------------------------"
    echo " COMMIT BLOCKED: potential secret detected in staged changes."
    echo " Options:"
    echo "  1. Move the value to a .env / SSM parameter."
    echo "  2. False positive? Append  # gitleaks:allow  to that line."
    echo "----------------------------------------------------------------"
    exit 1
fi
else
    echo "[pre-commit] WARNING: gitleaks not installed — secrets scan skipped."
fi
